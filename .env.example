# =============================================================================
# Metabase Production Environment Variables
# =============================================================================
# Copy this file to .env and replace all placeholder values.
# Generate secrets with: openssl rand -base64 32
# NEVER commit .env to version control.

# --- Image Versions ----------------------------------------------------------
METABASE_VERSION=latest
POSTGRES_VERSION=17-alpine

# --- Metabase Application Database -------------------------------------------
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase
MB_DB_PORT=5432
MB_DB_USER=metabase
MB_DB_PASS=
MB_DB_HOST=database

# --- Metabase Settings -------------------------------------------------------
# MB_EMBEDDING_APP_ORIGIN=https://metabase.example.com
# MB_EMBEDDING_SECRET_KEY=
# MAX_SESSION_AGE=20160
# MB_QUERY_CACHING_MAX_TTL=3024000

# --- Admin Setup (first run only) --------------------------------------------
# MB_SETUP_TOKEN=
# MB_ADMIN_EMAIL=
# MB_ADMIN_PASSWORD=
